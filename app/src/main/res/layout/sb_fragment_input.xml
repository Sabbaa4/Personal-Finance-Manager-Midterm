<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/sb_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sb_input_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/sb_margin_page"
        android:clipToPadding="false">

        <!-- Title -->
        <TextView
            android:id="@+id/sb_input_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/sb_input_title"
            android:textSize="@dimen/sb_title_size"
            android:textStyle="bold"
            android:textColor="@color/sb_text_primary"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/sb_input_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/sb_input_subtitle"
            android:textSize="@dimen/sb_subtitle_size"
            android:textColor="@color/sb_text_secondary"
            android:layout_marginTop="@dimen/sb_margin_small"
            app:layout_constraintTop_toBottomOf="@id/sb_input_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Input Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/sb_input_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/sb_card_bg"
            android:padding="20dp"
            android:layout_marginTop="@dimen/sb_margin_section"
            app:layout_constraintTop_toBottomOf="@id/sb_input_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- MONTHLY SALARY Label -->
            <TextView
                android:id="@+id/sb_label_salary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/sb_label_salary"
                android:textSize="@dimen/sb_label_size"
                android:textStyle="bold"
                android:textColor="@color/sb_text_secondary"
                android:letterSpacing="0.1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Salary EditText -->
            <EditText
                android:id="@+id/sb_edit_salary"
                android:layout_width="0dp"
                android:layout_height="@dimen/sb_edit_height"
                android:background="@drawable/sb_edit_bg"
                android:inputType="numberDecimal"
                android:hint="@string/sb_hint_amount"
                android:textColorHint="@color/sb_text_hint"
                android:textSize="@dimen/sb_body_size"
                android:textColor="@color/sb_text_primary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="@dimen/sb_margin_small"
                android:importantForAutofill="no"
                app:layout_constraintTop_toBottomOf="@id/sb_label_salary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- HOUSING / RENT Label -->
            <TextView
                android:id="@+id/sb_label_rent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/sb_label_rent"
                android:textSize="@dimen/sb_label_size"
                android:textStyle="bold"
                android:textColor="@color/sb_text_secondary"
                android:letterSpacing="0.1"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/sb_edit_salary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Rent EditText -->
            <EditText
                android:id="@+id/sb_edit_rent"
                android:layout_width="0dp"
                android:layout_height="@dimen/sb_edit_height"
                android:background="@drawable/sb_edit_bg"
                android:inputType="numberDecimal"
                android:hint="@string/sb_hint_amount"
                android:textColorHint="@color/sb_text_hint"
                android:textSize="@dimen/sb_body_size"
                android:textColor="@color/sb_text_primary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="@dimen/sb_margin_small"
                android:importantForAutofill="no"
                app:layout_constraintTop_toBottomOf="@id/sb_label_rent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- FOOD & DINING Label -->
            <TextView
                android:id="@+id/sb_label_food"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/sb_label_food"
                android:textSize="@dimen/sb_label_size"
                android:textStyle="bold"
                android:textColor="@color/sb_text_secondary"
                android:letterSpacing="0.1"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/sb_edit_rent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Food EditText -->
            <EditText
                android:id="@+id/sb_edit_food"
                android:layout_width="0dp"
                android:layout_height="@dimen/sb_edit_height"
                android:background="@drawable/sb_edit_bg"
                android:inputType="numberDecimal"
                android:hint="@string/sb_hint_amount"
                android:textColorHint="@color/sb_text_hint"
                android:textSize="@dimen/sb_body_size"
                android:textColor="@color/sb_text_primary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="@dimen/sb_margin_small"
                android:importantForAutofill="no"
                app:layout_constraintTop_toBottomOf="@id/sb_label_food"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Calculate Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/sb_btn_calculate"
            android:layout_width="0dp"
            android:layout_height="@dimen/sb_button_height"
            android:text="@string/sb_btn_calculate"
            android:textSize="@dimen/sb_body_size"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/sb_primary"
            app:cornerRadius="@dimen/sb_corner_radius"
            android:stateListAnimator="@null"
            android:layout_marginTop="@dimen/sb_margin_section"
            app:layout_constraintTop_toBottomOf="@id/sb_input_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
