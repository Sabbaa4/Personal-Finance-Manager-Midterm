<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/sb_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sb_result_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/sb_margin_page"
        android:clipToPadding="false">

        <!-- Title -->
        <TextView
            android:id="@+id/sb_result_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/sb_result_title"
            android:textSize="@dimen/sb_title_size"
            android:textStyle="bold"
            android:textColor="@color/sb_text_primary"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ======================== -->
        <!-- IDENTITY CARD            -->
        <!-- ======================== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/sb_identity_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/sb_card_bg"
            android:padding="20dp"
            android:layout_marginTop="@dimen/sb_margin_item"
            app:layout_constraintTop_toBottomOf="@id/sb_result_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Avatar Circle -->
            <TextView
                android:id="@+id/sb_identity_initials"
                android:layout_width="@dimen/sb_avatar_size"
                android:layout_height="@dimen/sb_avatar_size"
                android:background="@drawable/sb_avatar_bg"
                android:gravity="center"
                android:text="SB"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/sb_avatar_text"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- ACCOUNT IDENTITY Label -->
            <TextView
                android:id="@+id/sb_label_identity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/sb_label_identity"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/sb_text_secondary"
                android:letterSpacing="0.15"
                android:layout_marginTop="@dimen/sb_margin_item"
                app:layout_constraintTop_toBottomOf="@id/sb_identity_initials"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Name -->
            <TextView
                android:id="@+id/sb_identity_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/sb_subtitle_size"
                android:textColor="@color/sb_text_primary"
                android:layout_marginTop="6dp"
                app:layout_constraintTop_toBottomOf="@id/sb_label_identity"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Surname -->
            <TextView
                android:id="@+id/sb_identity_surname"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/sb_subtitle_size"
                android:textColor="@color/sb_text_primary"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/sb_identity_name"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Birth Year -->
            <TextView
                android:id="@+id/sb_identity_birth_year"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/sb_subtitle_size"
                android:textColor="@color/sb_text_primary"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/sb_identity_surname"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Blue Divider -->
        <View
            android:id="@+id/sb_divider"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="@color/sb_divider"
            android:layout_marginTop="@dimen/sb_margin_item"
            app:layout_constraintTop_toBottomOf="@id/sb_identity_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ======================== -->
        <!-- FISCAL CALCULATION       -->
        <!-- ======================== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/sb_fiscal_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/sb_card_bg"
            android:padding="20dp"
            android:layout_marginTop="@dimen/sb_margin_item"
            app:layout_constraintTop_toBottomOf="@id/sb_divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Section Label -->
            <TextView
                android:id="@+id/sb_label_fiscal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/sb_label_fiscal"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/sb_text_secondary"
                android:letterSpacing="0.15"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Total Inflows Label -->
            <TextView
                android:id="@+id/sb_label_inflows"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/sb_label_inflows"
                android:textSize="13sp"
                android:textColor="@color/sb_text_secondary"
                android:layout_marginTop="@dimen/sb_margin_item"
                app:layout_constraintTop_toBottomOf="@id/sb_label_fiscal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Salary Amount -->
            <TextView
                android:id="@+id/sb_result_salary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/sb_amount_medium"
                android:textStyle="bold"
                android:textColor="@color/sb_text_primary"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/sb_label_inflows"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Total Outflows Label -->
            <TextView
                android:id="@+id/sb_label_outflows"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/sb_label_outflows"
                android:textSize="13sp"
                android:textColor="@color/sb_text_secondary"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/sb_result_salary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Expenses Amount -->
            <TextView
                android:id="@+id/sb_result_expenses"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/sb_amount_medium"
                android:textStyle="bold"
                android:textColor="@color/sb_text_primary"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/sb_label_outflows"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ======================== -->
            <!-- HIGHLIGHT CARD           -->
            <!-- ======================== -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/sb_highlight_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/sb_result_highlight_bg"
                android:padding="16dp"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/sb_result_expenses"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Projected Capital Label -->
                <TextView
                    android:id="@+id/sb_label_capital"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/sb_label_capital"
                    android:textSize="13sp"
                    android:textColor="@color/sb_text_secondary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Balance Amount (color-coded) -->
                <TextView
                    android:id="@+id/sb_result_balance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/sb_amount_large"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/sb_label_capital"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Savings Rate Label -->
                <TextView
                    android:id="@+id/sb_label_savings_rate_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/sb_label_savings_rate"
                    android:textSize="12sp"
                    android:textColor="@color/sb_text_secondary"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/sb_result_balance"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/sb_label_status_title" />

                <!-- Status Label -->
                <TextView
                    android:id="@+id/sb_label_status_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/sb_label_status"
                    android:textSize="12sp"
                    android:textColor="@color/sb_text_secondary"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/sb_result_balance"
                    app:layout_constraintStart_toEndOf="@id/sb_label_savings_rate_title"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Savings Rate Value -->
                <TextView
                    android:id="@+id/sb_result_savings_rate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/sb_body_size"
                    android:textStyle="bold"
                    android:textColor="@color/sb_text_primary"
                    android:layout_marginTop="2dp"
                    app:layout_constraintTop_toBottomOf="@id/sb_label_savings_rate_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/sb_result_status" />

                <!-- Status Value -->
                <TextView
                    android:id="@+id/sb_result_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/sb_body_size"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    app:layout_constraintTop_toBottomOf="@id/sb_label_status_title"
                    app:layout_constraintStart_toEndOf="@id/sb_result_savings_rate"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Back Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/sb_btn_back"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/sb_button_height"
            android:text="@string/sb_btn_back"
            android:textSize="@dimen/sb_body_size"
            android:textStyle="bold"
            android:textColor="@color/sb_primary"
            app:backgroundTint="@color/sb_card_background"
            app:strokeColor="@color/sb_card_border"
            app:strokeWidth="1dp"
            app:cornerRadius="@dimen/sb_corner_radius"
            android:stateListAnimator="@null"
            android:layout_marginTop="@dimen/sb_margin_section"
            android:layout_marginBottom="@dimen/sb_margin_section"
            app:layout_constraintTop_toBottomOf="@id/sb_fiscal_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
